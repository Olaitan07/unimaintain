enum UserRole {
  STUDENT
  STAFF
  OFFICER
  ADMIN
}

enum RequestStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  passwordHash     String
  role             UserRole          @default(STUDENT)
  createdAt        DateTime          @default(now())
  createdRequests  ServiceRequest[]  @relation("RequestCreator")
  assignedRequests ServiceRequest[]  @relation("RequestAssignee")
  assignments      Assignment[]
  statusLogs       StatusLog[]       @relation("StatusChanger")
  notifications    Notification[]

  @@index([role])
  @@index([createdAt])
}

model Category {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  requests    ServiceRequest[]

  @@index([name])
}

model ServiceRequest {
  id            String         @id @default(cuid())
  title         String
  description   String
  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  status        RequestStatus  @default(PENDING)
  priority      Priority       @default(MEDIUM)
  location      String
  imageUrl      String?
  createdBy     User           @relation("RequestCreator", fields: [createdById], references: [id])
  createdById   String
  assignedTo    User?          @relation("RequestAssignee", fields: [assignedToId], references: [id])
  assignedToId  String?
  assignments   Assignment[]
  statusLogs    StatusLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([priority])
  @@index([categoryId])
  @@index([createdById])
  @@index([assignedToId])
}

model Assignment {
  id         String         @id @default(cuid())
  request    ServiceRequest @relation(fields: [requestId], references: [id])
  requestId  String
  officer    User           @relation(fields: [officerId], references: [id])
  officerId  String
  assignedAt DateTime       @default(now())
  notes      String?

  @@index([requestId])
  @@index([officerId])
  @@unique([requestId, officerId, assignedAt])
}

model StatusLog {
  id          String         @id @default(cuid())
  request     ServiceRequest @relation(fields: [requestId], references: [id])
  requestId   String
  changedBy   User           @relation("StatusChanger", fields: [changedById], references: [id])
  changedById String
  oldStatus   RequestStatus
  newStatus   RequestStatus
  comment     String?
  changedAt   DateTime       @default(now())

  @@index([requestId])
  @@index([changedById])
  @@index([changedAt])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

